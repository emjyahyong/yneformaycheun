# Copier ce fichier en ".env" et renseigner de vraies valeurs.
# Le ".env" ne doit jamais être commité (voir .gitignore).

POSTGRES_DB=yneformaycheun
POSTGRES_USER=yneformaycheun
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

APP_PORT=8080

# Port HÔTE du frontend (nginx) servant le build React + reverse proxy /api.
FRONTEND_PORT=80

# Secret de signature JWT (au moins 32 octets). Ne jamais committer une vraie valeur.
JWT_SECRET=change-me-please-with-a-32-bytes-min-secret

# Origine(s) autorisée(s) du frontend pour le CORS (séparées par des virgules).
CORS_ALLOWED_ORIGINS=http://localhost:5173
